[
  {
    "item_id": "cp_36228",
    "riddle_text": "在清理旧物时，他找到一张自己穿着不同制服的照片，顿时冷汗直流。",
    "anchor_word": "叛徒",
    "cue_word": "发现",
    "cue_bin": "far"
  },
  {
    "item_id": "cp_15036",
    "riddle_text": "航班延误五小时，所有乘客安静等待，唯独他对着登机口鞠躬。",
    "anchor_word": "生活",
    "cue_word": "飞机",
    "cue_bin": "far"
  },
  {
    "item_id": "cp_45393",
    "riddle_text": "探险队断粮多日，队长将最后一点“营养剂”分给了队员，自己却虚弱倒下。",
    "anchor_word": "致死",
    "cue_word": "拯救",
    "cue_bin": "far"
  },
  {
    "item_id": "cp_45397",
    "riddle_text": "他从不让人清洗他的专用茶杯，每次喝水前，都会仔细检查杯底。",
    "anchor_word": "致死",
    "cue_word": "水杯",
    "cue_bin": "far"
  },
  {
    "item_id": "cp_54566",
    "riddle_text": "虔诚的教徒收到一封信，看完后便不再祈祷，只是每天望着天空出神。",
    "anchor_word": "生命",
    "cue_word": "上帝",
    "cue_bin": "far"
  },
  {
    "item_id": "cp_54567",
    "riddle_text": "备受病痛折磨的老人，某天突然精神焕发，把心爱之物全部分送给了孙辈。",
    "anchor_word": "生命",
    "cue_word": "解脱",
    "cue_bin": "far"
  },
  {
    "item_id": "cp_39853",
    "riddle_text": "电视上有个比赛，选手们不唱歌也不跳舞，而是轮流用押韵的句子互相攻击对方。",
    "anchor_word": "美国",
    "cue_word": "节目",
    "cue_bin": "far"
  },
  {
    "item_id": "cp_8574",
    "riddle_text": "设施启动的铃声一响，队伍里就有人开始尖叫着往后缩。",
    "anchor_word": "害怕",
    "cue_word": "吓人",
    "cue_bin": "far"
  },
  {
    "item_id": "cp_8575",
    "riddle_text": "启动瞬间他感觉被狠狠按在椅背上，血液都涌向了脚底。",
    "anchor_word": "害怕",
    "cue_word": "加速度",
    "cue_bin": "far"
  },
  {
    "item_id": "cp_8576",
    "riddle_text": "最恐怖的是那段轨道，车体几乎与地面成了九十度角。",
    "anchor_word": "害怕",
    "cue_word": "垂直",
    "cue_bin": "far"
  },
  {
    "item_id": "cp_8577",
    "riddle_text": "结束后他冲进洗手间，外面的人听到里面传来剧烈的干呕声。",
    "anchor_word": "害怕",
    "cue_word": "呕吐",
    "cue_bin": "far"
  },
  {
    "item_id": "cp_36225",
    "riddle_text": "他每晚准时收看一部老式谍战剧，并认真记录剧中人物的对话习惯。",
    "anchor_word": "叛徒",
    "cue_word": "电视剧",
    "cue_bin": "mid"
  },
  {
    "item_id": "cp_15031",
    "riddle_text": "事故后，他总在深夜对着行车记录仪反复播放那段录音。",
    "anchor_word": "生活",
    "cue_word": "车祸",
    "cue_bin": "mid"
  },
  {
    "item_id": "cp_45389",
    "riddle_text": "为了掩盖一个更大的秘密，他在审讯前，主动要求喝一杯水。",
    "anchor_word": "致死",
    "cue_word": "犯罪",
    "cue_bin": "mid"
  },
  {
    "item_id": "cp_54564",
    "riddle_text": "病人突然要求停止用药，并让家人把病房的日历翻到三个月后的某一天。",
    "anchor_word": "生命",
    "cue_word": "疾病",
    "cue_bin": "mid"
  },
  {
    "item_id": "cp_54565",
    "riddle_text": "他在网上精确搜索“无痛方法”，并设定了一个三天后的手机提醒。",
    "anchor_word": "生命",
    "cue_word": "自杀",
    "cue_bin": "mid"
  },
  {
    "item_id": "cp_39846",
    "riddle_text": "他的表演没有旋律，全靠嘴皮子和脚打拍子，却让整个房间的人都跟着摇摆。",
    "anchor_word": "美国",
    "cue_word": "节奏",
    "cue_bin": "mid"
  },
  {
    "item_id": "cp_8570",
    "riddle_text": "设施明明标着身高限制，可入口处总传来孩子的哭闹声。",
    "anchor_word": "害怕",
    "cue_word": "儿童",
    "cue_bin": "mid"
  },
  {
    "item_id": "cp_8571",
    "riddle_text": "他感觉自己像被弹射出去，紧接着头朝下冲向了地面。",
    "anchor_word": "害怕",
    "cue_word": "飞行",
    "cue_bin": "mid"
  },
  {
    "item_id": "cp_36217",
    "riddle_text": "庆功宴上，他笑着与众人碰杯，却在桌下将一张纸条悄悄塞进袖口。",
    "anchor_word": "叛徒",
    "cue_word": "背叛",
    "cue_bin": "near"
  },
  {
    "item_id": "cp_15023",
    "riddle_text": "他不停地向朋友诉说，但朋友只是听着，什么也没做。",
    "anchor_word": "生活",
    "cue_word": "难过",
    "cue_bin": "near"
  },
  {
    "item_id": "cp_45384",
    "riddle_text": "他拒绝所有治疗，坚持要出院回家，却在当晚平静地喝下了一杯白水。",
    "anchor_word": "致死",
    "cue_word": "医院",
    "cue_bin": "near"
  },
  {
    "item_id": "cp_45387",
    "riddle_text": "晚宴上，唯独他没有碰那瓶众人称赞的、色泽深邃的佳酿。",
    "anchor_word": "致死",
    "cue_word": "黑色",
    "cue_bin": "near"
  },
  {
    "item_id": "cp_54557",
    "riddle_text": "他在日历上圈出今天，然后烧掉了所有日记，坐在摇椅上静静等待。",
    "anchor_word": "生命",
    "cue_word": "结束",
    "cue_bin": "near"
  },
  {
    "item_id": "cp_54558",
    "riddle_text": "他收到一个没有寄件人的包裹，里面只有一张写着明天日期的纸条。",
    "anchor_word": "生命",
    "cue_word": "日子",
    "cue_bin": "near"
  },
  {
    "item_id": "cp_39842",
    "riddle_text": "这段表演里没有歌唱，只有快速的念白和强烈的鼓点，却引爆了音乐节的气氛。",
    "anchor_word": "美国",
    "cue_word": "音乐",
    "cue_bin": "near"
  },
  {
    "item_id": "cp_39843",
    "riddle_text": "他写的不是诗，但每句话都押韵且节奏感强，内容是关于街头的真实生活。",
    "anchor_word": "美国",
    "cue_word": "歌词",
    "cue_bin": "near"
  },
  {
    "item_id": "cp_8563",
    "riddle_text": "他紧紧抓住扶手，明明在室内，却感觉风从耳边呼啸而过。",
    "anchor_word": "害怕",
    "cue_word": "高空",
    "cue_bin": "near"
  },
  {
    "item_id": "cp_8564",
    "riddle_text": "周末她去了那个地方，回来时头发全都竖了起来，声音嘶哑。",
    "anchor_word": "害怕",
    "cue_word": "游乐园",
    "cue_bin": "near"
  },
  {
    "item_id": "cp_8567",
    "riddle_text": "他梦见自己从万丈悬崖跌落，惊醒时发现自己被安全带绑着。",
    "anchor_word": "害怕",
    "cue_word": "坠落",
    "cue_bin": "near"
  }
]